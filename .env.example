# Copia este fichero a .env y rellena los valores.
# .env esta en .gitignore: nunca se versiona.

# --- PostgreSQL ---
# Local:
#   postgres://postgres:postgres@localhost:5432/aluminior
# Supabase (usa el "Connection pooling" en region UE):
#   postgres://postgres.PROYECTO:CLAVE@aws-0-eu-west-1.pooler.supabase.com:6543/postgres
DATABASE_URL=postgres://postgres:postgres@localhost:5432/aluminior

# --- Carga de datos ---
# Carpeta con los CSV exportados del sistema original.
# Fuera del repositorio: contiene datos reales de clientes.
RUTA_CSV_ORIGEN=C:/Users/laral/OneDrive/Documentos/Aluminior/export_datos/EMP0016

# --- API ---
PORT=3000
NODE_ENV=development

# --- Supabase (auth / API) ---
SUPABASE_URL=https://PROYECTO.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_JWKS_URL=https://PROYECTO.supabase.co/auth/v1/.well-known/jwks.json

# --- Render ---
RENDER_Service_ID=
RENDER_URL=
RENDER_API=