{
  "name": "aluminior",
  "version": "0.1.0",
  "private": true,
  "description": "Sistema de gestion para carpinteria de aluminio y PVC",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "db:generate": "npm run -w @aluminior/db generate",
    "db:migrate": "npm run -w @aluminior/db migrate",
    "etl": "npm run -w @aluminior/etl import",
    "dev:api": "npm run -w @aluminior/api dev",
    "dev:web": "npm run -w @aluminior/web dev",
    "test": "npm run -ws --if-present test",
    "typecheck": "npm run -ws --if-present typecheck"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  },
  "allowScripts": {
    "esbuild@0.18.20": true,
    "esbuild@0.19.12": true,
    "esbuild@0.28.1": true,
    "esbuild@0.21.5": true,
    "sharp@0.34.5": true
  }
}
